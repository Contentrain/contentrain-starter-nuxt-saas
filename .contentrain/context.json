{
  "content": {
    "default_locale": "en",
    "domains": [
      {
        "description": "Global site chrome, SEO defaults, and reusable platform settings.",
        "id": "system",
        "models": [
          "site-settings",
          "navigation",
          "footer",
          "seo-defaults"
        ]
      },
      {
        "description": "Marketing surfaces such as hero sections, features, testimonials, and FAQs.",
        "id": "marketing",
        "models": [
          "hero",
          "feature",
          "pricing-tier",
          "testimonial",
          "faq-item"
        ]
      },
      {
        "description": "Product surface content such as integrations and changelog entries.",
        "id": "product",
        "models": [
          "integration",
          "changelog-entry"
        ]
      }
    ],
    "i18n_strategy": "file-per-locale",
    "import_pattern": "import { query, getCollection, getDocument, getSingleton } from '#contentrain'",
    "supported_locales": [
      "en"
    ]
  },
  "conventions": {
    "allowed_richtext_tags": [
      "p",
      "strong",
      "em",
      "a",
      "ul",
      "ol",
      "li",
      "h2",
      "h3",
      "h4",
      "h5",
      "h6",
      "blockquote",
      "code",
      "pre",
      "img",
      "br",
      "hr",
      "table",

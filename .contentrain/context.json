      "tbody",
      "tr",
      "th",
      "td",
      "del",
      "ins",
      "sup",
      "sub",
      "abbr",
      "mark",
      "details",
      "summary"
    ],
    "brand_terms": {
      "company_name": "Contentrain",
      "product_name": "Contentrain Nuxt SaaS"
    },
    "forbidden_terms": [
      "click here",
      "lorem ipsum",
      "TODO",
      "TBD"
    ],
    "max_description_length": 158,
    "max_title_length": 76,
    "target_reading_level": "grade-8",
